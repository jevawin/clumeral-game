{
  "name": "clumeral-game",
  "compatibility_date": "2026-03-09",
  "main": "./src/worker/index.ts",
  "assets": {
    "binding": "ASSETS",
    "run_worker_first": ["/", "/index.html", "/random", "/api/*", "/stats"]
  },
  "analytics_engine_datasets": [
    {
      "binding": "ANALYTICS",
      "dataset": "clumeral"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "PUZZLES",
      "id": "PLACEHOLDER_PROD_ID"
    }
  ],
  "triggers": {
    "crons": ["0 0 * * *"]
  }
}
